# Public.com API credentials — set ONE of the two options below.
#
# Option A: Pre-generated personal access token (from Public app or API settings)
PUBLIC_ACCESS_TOKEN=your_access_token_here
#
# Option B: API secret key (the terminal will generate bearer tokens automatically)
# PUBLIC_API_SECRET_KEY=your_api_secret_key_here

# Optional: default account number so you don't have to pass it on every call
# PUBLIC_ACCOUNT_NUMBER=your_account_number_here
